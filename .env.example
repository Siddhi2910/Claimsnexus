# ── Application ──────────────────────────────────────────────
APP_NAME=ClaimsNexus
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_V1_PREFIX=/api/v1

# ── LLM Provider (OpenAI-format) ──────────────────────────────
# Choose one: openai | together | ollama
MODEL_PROVIDER=together
# Provider model (Together uses Together-hosted model ids, not OpenAI model names)
LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Gemini (primary in unified fallback layer)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Together (OpenAI-compatible)
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.ai

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# Unified layer stability controls
LLM_CONCURRENCY=1
LLM_MIN_DELAY_SECONDS=1.2
LLM_MAX_OUTPUT_TOKENS=250
LLM_CACHE_TTL_SECONDS=600

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_ARBITER_MODEL=claude-opus-4-7
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=claimsnexus
POSTGRES_USER=claimsnexus
POSTGRES_PASSWORD=claimsnexus_secret
DATABASE_URL=postgresql+asyncpg://claimsnexus:claimsnexus_secret@localhost:5432/claimsnexus

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Weaviate ──────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# ── Risk Scoring Weights ──────────────────────────────────────
RISK_WEIGHT_FRAUD=0.45
RISK_WEIGHT_MEDICAL=0.30
RISK_WEIGHT_POLICY=0.25

# ── Routing Thresholds ────────────────────────────────────────
RISK_FAST_TRACK_MAX=0.25
RISK_STANDARD_MAX=0.50
RISK_FULL_MAX=0.70
RISK_ESCALATE_MIN=0.86
FRAUD_AUTO_REJECT_THRESHOLD=0.85
CLAIM_FAST_TRACK_VALUE_MAX=1000.0

# ── Debate Settings ───────────────────────────────────────────
DEBATE_MAX_ROUNDS=3
DEBATE_SIMILARITY_THRESHOLD=0.90

# ── Human Review ──────────────────────────────────────────────
HUMAN_REVIEW_ENABLED=true
HUMAN_REVIEW_TIMEOUT_HOURS=48

# ── Notifications ─────────────────────────────────────────────
NOTIFICATION_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
